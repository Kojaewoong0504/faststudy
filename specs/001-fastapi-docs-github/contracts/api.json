{
  "openapi": "3.0.0",
  "info": {
    "title": "Practical FastAPI Learning API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/categories": {
      "get": {
        "summary": "List all content categories",
        "responses": {
          "200": {
            "description": "A list of categories.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/tutorials/{tutorial_id}": {
      "get": {
        "summary": "Get a specific tutorial by ID",
        "parameters": [
          {
            "name": "tutorial_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The tutorial content.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "category_id": { "type": "string" },
                    "title": { "type": "string" },
                    "content": { "type": "string" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Tutorial not found"
          }
        }
      }
    }
  }
}
